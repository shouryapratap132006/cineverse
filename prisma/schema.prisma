datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                     String            @id // Matches Clerk User ID (e.g. user_...)
  email                  String            @unique
  createdAt              DateTime          @default(now())
  profile                Profile?
  watchlists             Watchlist[]
  favorites              Favorite[]
  reviews                Review[]
  diaryEntries           DiaryEntry[]
  lists                  CineverseList[]
  posts                  Post[]
  comments               Comment[]
  likes                  Like[]
  reactions              Reaction[]
  followers              Follow[]          @relation("Followers")
  following              Follow[]          @relation("Following")
  memberships            CommunityMember[]
  votes                  Vote[]
  messages               Message[]
  stories                Story[]
  activities             Activity[]
  achievements           Achievement[]
  conversations          Conversation[]    @relation("ConversationToUser")
  
  notificationsReceived  Notification[]    @relation("NotificationReceiver")
  notificationsSent      Notification[]    @relation("NotificationActor")
  
  friendRequestsSent     FriendRequest[]   @relation("FriendRequestSender")
  friendRequestsReceived FriendRequest[]   @relation("FriendRequestReceiver")
  
  filmClubMemberships    FilmClubMember[]  @relation("FilmClubMemberships")
  filmClubsOwned         FilmClub[]        @relation("FilmClubOwner")
  eventsCreated          Event[]           @relation("EventCreator")
  eventRsvps             EventRSVP[]
  bookmarks              Bookmark[]
  reports                Report[]
}

model Profile {
  id                String   @id // Matches User.id
  user              User     @relation(fields: [id], references: [id], onDelete: Cascade)
  username          String   @unique
  bio               String?  @db.Text
  avatarUrl         String?
  bannerUrl         String?
  favoriteGenres    String[]
  favoriteMovies    String[]
  favoriteActors    String[]
  favoriteDirectors String[]
  language          String   @default("English")
  country           String   @default("United States")
  reputation        String   @default("Bronze Star")
  updatedAt         DateTime @updatedAt
}

model Movie {
  id           String        @id // TMDB Movie ID
  title        String
  posterPath   String?
  releaseDate  String?
  watchlists   Watchlist[]
  favorites    Favorite[]
  reviews      Review[]
  diaryEntries DiaryEntry[]
  listEntries  ListEntry[]
  posts        Post[]
  stories      Story[]
}

model Watchlist {
  id      String @id @default(uuid())
  userId  String
  movieId String
  status  String // WANT_TO_WATCH, WATCHED
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie   Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@index([userId])
  @@index([movieId])
}

model Favorite {
  id      String @id @default(uuid())
  userId  String
  movieId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie   Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@index([userId])
  @@index([movieId])
}

model Review {
  id               String      @id @default(uuid())
  userId           String
  movieId          String
  rating           Int // Out of 10
  content          String      @db.Text
  containsSpoilers Boolean     @default(false)
  isRewatch        Boolean     @default(false)
  visibility       String      @default("PUBLIC") // PUBLIC, FRIENDS, PRIVATE
  watchedAt        DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie            Movie       @relation(fields: [movieId], references: [id], onDelete: Cascade)
  comments         Comment[]
  likes            Like[]
  reactions        Reaction[]
  diaryEntry       DiaryEntry?
  bookmarks        Bookmark[]

  @@index([userId])
  @@index([movieId])
}

model DiaryEntry {
  id         String   @id @default(uuid())
  userId     String
  movieId    String
  reviewId   String?  @unique
  watchedAt  DateTime
  rating     Int?     // Out of 10
  notes      String?  @db.Text
  isRewatch  Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie      Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  review     Review?  @relation(fields: [reviewId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([movieId])
  @@index([watchedAt])
}

model CineverseList {
  id          String      @id @default(uuid())
  userId      String
  name        String
  description String?     @db.Text
  isRanked    Boolean     @default(false)
  isPublic    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries     ListEntry[]

  @@index([userId])
}

model ListEntry {
  id        String        @id @default(uuid())
  listId    String
  movieId   String
  rank      Int?
  notes     String?       @db.Text
  addedAt   DateTime      @default(now())
  list      CineverseList @relation(fields: [listId], references: [id], onDelete: Cascade)
  movie     Movie         @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([listId, movieId])
  @@index([listId])
  @@index([movieId])
}

model Post {
  id             String          @id @default(uuid())
  userId         String
  type           String          @default("TEXT") // TEXT, MOVIE, REVIEW, POLL, IMAGE
  content        String          @db.Text
  imageUrl       String?
  gifUrl         String?
  movieId        String?
  spoilerTag     Boolean         @default(false)
  mentions       String[]        // Array of user IDs
  hashtags       String[]
  createdAt      DateTime        @default(now())
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie          Movie?          @relation(fields: [movieId], references: [id], onDelete: SetNull)
  comments       Comment[]
  likes          Like[]
  reactions      Reaction[]
  communityPosts CommunityPost[]
  poll           Poll?
  bookmarks      Bookmark[]

  @@index([userId])
  @@index([movieId])
}

model Comment {
  id        String    @id @default(uuid())
  userId    String
  postId    String?
  reviewId  String?
  parentId  String?
  content   String    @db.Text
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post?     @relation(fields: [postId], references: [id], onDelete: Cascade)
  review    Review?   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  likes     Like[]
  reactions Reaction[]

  @@index([userId])
  @@index([postId])
  @@index([reviewId])
}

// Retaining Like for backwards compatibility, but adding Reaction
model Like {
  id        String   @id @default(uuid())
  userId    String
  postId    String?
  commentId String?
  reviewId  String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  review    Review?  @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([postId])
  @@index([commentId])
  @@index([reviewId])
}

model Reaction {
  id        String   @id @default(uuid())
  userId    String
  postId    String?
  commentId String?
  reviewId  String?
  emoji     String   // LIKE, FIRE, CINE, FUNNY, WOW, EMOTIONAL, CLAP
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  review    Review?  @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([postId])
  @@index([commentId])
  @@index([reviewId])
}

model Follow {
  id          String @id @default(uuid())
  followerId  String
  followingId String
  follower    User   @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User   @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model FriendRequest {
  id          String   @id @default(uuid())
  senderId    String
  receiverId  String
  status      String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sender      User     @relation("FriendRequestSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User     @relation("FriendRequestReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
}

model Community {
  id             String            @id @default(uuid())
  name           String            @unique
  slug           String            @unique
  description    String            @db.Text
  type           String            @default("USER_CREATED") // MOVIE, GENRE, STUDIO, ACTOR, DIRECTOR, USER_CREATED
  tmdbId         String?           // Optional TMDB ID if linked to movie/actor
  bannerUrl      String?
  avatarUrl      String?
  createdAt      DateTime          @default(now())
  rules          String[]
  events         String[]
  members        CommunityMember[]
  communityPosts CommunityPost[]
  communityEvents Event[]
}

model CommunityMember {
  id          String    @id @default(uuid())
  communityId String
  userId      String
  role        String    @default("MEMBER") // OWNER, ADMIN, MODERATOR, VERIFIED_CREATOR, MEMBER, MUTED, BANNED
  joinedAt    DateTime  @default(now())
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([communityId])
  @@index([userId])
}

model CommunityPost {
  id          String    @id @default(uuid())
  communityId String
  postId      String
  isPinned    Boolean   @default(false)
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  post        Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([communityId, postId])
  @@index([communityId])
  @@index([postId])
}

model Poll {
  id       String   @id @default(uuid())
  postId   String   @unique
  question String
  options  String[]
  post     Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  votes    Vote[]
}

model Vote {
  id          String   @id @default(uuid())
  pollId      String
  userId      String
  optionIndex Int
  poll        Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
  @@index([pollId])
  @@index([userId])
}

model Conversation {
  id        String    @id @default(uuid())
  isGroup   Boolean   @default(false)
  name      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
  users     User[]    @relation("ConversationToUser")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String       @db.Text
  seenBy         String[]     // Array of user IDs who have seen the message
  sentAt         DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
}

model Story {
  id        String   @id @default(uuid())
  userId    String
  movieId   String
  content   String   @db.Text
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Activity {
  id          String   @id @default(uuid())
  userId      String
  type        String // POST, REVIEW, WATCHLIST, FOLLOW
  description String   @db.Text
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Badge {
  id           String        @id @default(uuid())
  name         String        @unique
  description  String
  icon         String
  achievements Achievement[]
}

model Achievement {
  id       String   @id @default(uuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([badgeId])
}

model Notification {
  id          String   @id @default(uuid())
  receiverId  String
  actorId     String?
  type        String   // LIKE, COMMENT, REPLY, MENTION, FRIEND_REQUEST, ACCEPTED, MESSAGE, INVITE
  targetId    String?  // ID of the post, comment, etc.
  link        String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  receiver    User     @relation("NotificationReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  actor       User?    @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([receiverId])
  @@index([isRead])
  @@index([createdAt])
}

model Event {
  id          String      @id @default(uuid())
  communityId String
  creatorId   String
  title       String
  description String?     @db.Text
  date        DateTime
  movieId     String?
  movieTitle  String?
  createdAt   DateTime    @default(now())

  community   Community   @relation(fields: [communityId], references: [id], onDelete: Cascade)
  creator     User        @relation("EventCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  rsvps       EventRSVP[]

  @@index([communityId])
  @@index([date])
  @@index([creatorId])
}

model EventRSVP {
  id       String   @id @default(uuid())
  eventId  String
  userId   String
  status   String   @default("GOING") // GOING, INTERESTED, NOT_GOING

  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model FilmClub {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  isPublic    Boolean  @default(true)
  bannerUrl   String?
  ownerId     String?
  createdAt   DateTime @default(now())

  owner       User?          @relation("FilmClubOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  members     FilmClubMember[]
  watchlist   FilmClubMovie[]
}

model FilmClubMember {
  id         String   @id @default(uuid())
  clubId     String
  userId     String
  role       String   @default("MEMBER")
  joinedAt   DateTime @default(now())

  club       FilmClub @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user       User     @relation("FilmClubMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@index([clubId])
  @@index([userId])
}

model FilmClubMovie {
  id         String   @id @default(uuid())
  clubId     String
  tmdbId     String
  title      String
  posterPath String?
  addedById  String?
  addedAt    DateTime @default(now())

  club       FilmClub @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, tmdbId])
  @@index([clubId])
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  postId    String?
  reviewId  String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  review    Review?  @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([postId])
  @@index([reviewId])
}

model Report {
  id          String   @id @default(uuid())
  reporterId  String
  targetType  String   // POST, COMMENT, USER, REVIEW, COMMUNITY
  targetId    String
  reason      String   @db.Text
  status      String   @default("PENDING") // PENDING, RESOLVED, DISMISSED
  createdAt   DateTime @default(now())

  reporter    User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([targetType, targetId])
}

// Hashtags can be extracted from text at runtime, or stored in a separate table for fast trending calculations
// We will rely on simple text search or Post array for now
