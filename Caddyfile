# Reverse proxy for Cineverse.
# SITE_ADDRESS is read from .env:
#   - unset            -> serve plain HTTP on :80 (fine for a raw EC2 IP)
#   - a domain name    -> Caddy auto-provisions a Let's Encrypt HTTPS cert
# Socket.IO (/api/socket) is proxied transparently — Caddy upgrades WebSockets automatically.

{$SITE_ADDRESS::80} {
	encode zstd gzip
	reverse_proxy app:3000
}
